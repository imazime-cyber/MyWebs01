<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
  function dcfVal(r, g, cf1, years) {
    if (r <= g) return null;
    let pv = 0;
    for (let t = 1; t <= years; t++) {
      pv += cf1 * Math.pow(1 + g, t - 1) / Math.pow(1 + r, t);
    }
    const tv = (cf1 * Math.pow(1 + g, years) * (1 + g)) / ((r - g) * Math.pow(1 + r, years));
    return pv + tv;
  }

  let chart;
  function update() {
    const r  = parseFloat(document.getElementById('r').value) / 100;
    const dr = parseFloat(document.getElementById('dr').value) / 100;
    document.getElementById('r-out').textContent  = (r  * 100).toFixed(1) + '%';
    document.getElementById('dr-out').textContent = '+' + (dr * 100).toFixed(1) + '%p';

    const cases = [
      { id: 'low', g: 0.03 },
      { id: 'mid', g: 0.08 },
      { id: 'hi',  g: 0.12 },
    ];

    const deltas = [];
    cases.forEach(c => {
      const v0 = dcfVal(r, c.g, 100, 30);
      const v1 = dcfVal(r + dr, c.g, 100, 30);
      if (!v0 || !v1) {
        document.getElementById('val-' + c.id).textContent = 'N/A';
        document.getElementById('dlt-' + c.id).textContent = 'r ≤ g';
        document.getElementById('dlt-' + c.id).style.color = '#e05c3a';
        deltas.push(0);
        return;
      }
      const pct = ((v1 - v0) / v0) * 100;
      document.getElementById('val-' + c.id).textContent = Math.round(v0).toLocaleString();
      document.getElementById('dlt-' + c.id).textContent = pct.toFixed(1) + '%';
      document.getElementById('dlt-' + c.id).style.color = pct < 0 ? '#e05c3a' : '#4caf82';
      deltas.push(parseFloat(pct.toFixed(1)));
    });

    const barColors = deltas.map(d =>
      d < -25 ? '#cc3c28' : d < -15 ? '#e05c3a' : d < -8 ? '#f0a830' : '#4caf82'
    );

    if (chart) {
      chart.data.datasets[0].data = deltas;
      chart.data.datasets[0].backgroundColor = barColors;
      chart.update();
    } else {
      chart = new Chart(document.getElementById('dcfChart'), {
        type: 'bar',
        data: {
          labels: ['저PER 가치주 (g=3%)', '고PER 성장주 (g=8%)', '무수익 테크 (g=12%)'],
          datasets: [{
            label: '주가 변화율 (%)',
            data: deltas,
            backgroundColor: barColors,
            borderWidth: 0,
            borderRadius: 4,
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#1a1e25',
              borderColor: 'rgba(255,255,255,0.1)',
              borderWidth: 0.5,
              titleColor: '#9a9b9f',
              bodyColor: '#e8e6df',
              callbacks: { label: ctx => ' ' + ctx.parsed.y.toFixed(1) + '%' }
            }
          },
          scales: {
            y: {
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: { color: '#6b6d72', font: { family: "'IBM Plex Mono', monospace", size: 11 }, callback: v => v.toFixed(0) + '%' }
            },
            x: {
              grid: { display: false },
              ticks: { color: '#6b6d72', font: { family: "'IBM Plex Sans KR', sans-serif", size: 11 } }
            }
          }
        }
      });
    }
  }

  document.getElementById('r').addEventListener('input', update);
  document.getElementById('dr').addEventListener('input', update);
  update();
</script>
