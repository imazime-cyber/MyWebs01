<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>손익계산서 흐름도</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #ffffff;
    --bg2: #f5f5f3;
    --text: #1a1a18;
    --text2: #5f5e5a;
    --border: rgba(0,0,0,0.12);
    --border2: rgba(0,0,0,0.22);
    --radius-md: 8px;
    --radius-lg: 12px;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1c1c1a;
      --bg2: #2a2a28;
      --text: #e8e6de;
      --text2: #9c9a92;
      --border: rgba(255,255,255,0.1);
      --border2: rgba(255,255,255,0.2);
    }
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 32px 16px 48px;
  }

  .card {
    background: var(--bg);
    border: 0.5px solid var(--border2);
    border-radius: var(--radius-lg);
    padding: 28px 24px 24px;
    width: 100%;
    max-width: 720px;
  }

  h1 {
    font-size: 17px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 4px;
  }
  .subtitle {
    font-size: 12px;
    color: var(--text2);
    margin-bottom: 20px;
  }

  .step-label {
    font-size: 12px;
    color: var(--text2);
    margin-bottom: 14px;
    min-height: 20px;
  }

  .row {
    display: flex;
    align-items: stretch;
    gap: 8px;
    margin-bottom: 6px;
    transition: opacity 0.4s, transform 0.4s;
  }
  .row.faded {
    opacity: 0.18;
    transform: scaleY(0.85);
    pointer-events: none;
  }
  .label-col {
    width: 210px;
    min-width: 210px;
    display: flex;
    align-items: center;
  }
  .label-box {
    width: 100%;
    padding: 10px 13px;
    border-radius: var(--radius-md);
    border: 0.5px solid;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.4;
  }
  .label-box span {
    font-weight: 400;
    font-size: 11px;
    display: block;
  }
  .bar-col {
    flex: 1;
    display: flex;
    align-items: center;
    min-height: 48px;
  }
  .bar-track {
    position: relative;
    height: 36px;
    width: 100%;
    border-radius: var(--radius-md);
    background: var(--bg2);
    overflow: hidden;
  }
  .bar-fill {
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    border-radius: var(--radius-md);
    transition: width 0.55s cubic-bezier(.4,0,.2,1);
  }
  .bar-label {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
  }
  .op-badge {
    width: 28px;
    min-width: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 500;
    color: var(--text2);
  }

  .sub-rows {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.4s ease, opacity 0.3s;
  }
  .sub-rows.open {
    max-height: 300px;
    opacity: 1;
  }
  .sub-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
    padding-left: 16px;
  }
  .sub-label {
    width: 194px;
    min-width: 194px;
    padding: 7px 11px;
    border-radius: var(--radius-md);
    border: 0.5px solid;
    font-size: 12px;
    color: var(--text2);
  }
  .sub-bar-track {
    flex: 1;
    height: 24px;
    border-radius: var(--radius-md);
    background: var(--bg2);
    overflow: hidden;
    position: relative;
  }
  .sub-bar-fill {
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    border-radius: var(--radius-md);
    transition: width 0.55s cubic-bezier(.4,0,.2,1);
  }
  .sub-bar-label {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 11px;
    font-weight: 500;
  }

  .controls {
    display: flex;
    gap: 10px;
    margin-top: 20px;
    align-items: center;
    flex-wrap: wrap;
  }
  button {
    padding: 8px 18px;
    font-size: 13px;
    border: 0.5px solid var(--border2);
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--text);
    cursor: pointer;
    transition: background 0.15s;
  }
  button:hover { background: var(--bg2); }
  button:disabled { opacity: 0.35; cursor: default; }
  .btn-reset { color: var(--text2); }

  .step-dots {
    display: flex;
    gap: 6px;
    margin-left: auto;
    align-items: center;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border2);
    transition: background 0.2s;
  }
  .dot.active { background: var(--text2); }
</style>
</head>
<body>
<div class="card">
  <h1>손익계산서 흐름도</h1>
  <p class="subtitle">Revenue → COGS → Gross Profit → SG&A → Operating Profit → Net Income</p>

  <div class="step-label" id="step-label">▶ 시작을 눌러 단계별로 확인하세요</div>

  <!-- A. 매출액 -->
  <div class="row" id="row-revenue">
    <div class="label-col">
      <div class="label-box" style="background:#E6F1FB;border-color:#185FA5;color:#0C447C;">
        A. 매출액<span style="color:#185FA5">국내·수출·온라인</span>
      </div>
    </div>
    <div class="op-badge"></div>
    <div class="bar-col">
      <div class="bar-track">
        <div class="bar-fill" id="bar-revenue" style="background:#378ADD;width:0%"></div>
        <span class="bar-label" id="lbl-revenue" style="color:#0C447C"></span>
      </div>
    </div>
  </div>
  <div class="sub-rows" id="sub-revenue">
    <div class="sub-row">
      <div class="sub-label" style="background:#E6F1FB;border-color:#B5D4F4;color:#185FA5">국내 판매</div>
      <div class="sub-bar-track"><div class="sub-bar-fill" id="sb-domestic" style="background:#85B7EB;width:0%"></div><span class="sub-bar-label" id="sl-domestic" style="color:#0C447C"></span></div>
    </div>
    <div class="sub-row">
      <div class="sub-label" style="background:#E6F1FB;border-color:#B5D4F4;color:#185FA5">수출</div>
      <div class="sub-bar-track"><div class="sub-bar-fill" id="sb-export" style="background:#85B7EB;width:0%"></div><span class="sub-bar-label" id="sl-export" style="color:#0C447C"></span></div>
    </div>
    <div class="sub-row">
      <div class="sub-label" style="background:#E6F1FB;border-color:#B5D4F4;color:#185FA5">온라인 판매</div>
      <div class="sub-bar-track"><div class="sub-bar-fill" id="sb-online" style="background:#85B7EB;width:0%"></div><span class="sub-bar-label" id="sl-online" style="color:#0C447C"></span></div>
    </div>
  </div>

  <!-- B. 판매원가 -->
  <div class="row faded" id="row-cogs">
    <div class="label-col">
      <div class="label-box" style="background:#FAECE7;border-color:#993C1D;color:#712B13;">
        B. 판매원가 (COGS)<span style="color:#993C1D">원재료·노동·제조간접비</span>
      </div>
    </div>
    <div class="op-badge" style="color:#D85A30">−</div>
    <div class="bar-col">
      <div class="bar-track">
        <div class="bar-fill" id="bar-cogs" style="background:#D85A30;width:0%"></div>
        <span class="bar-label" id="lbl-cogs" style="color:#712B13"></span>
      </div>
    </div>
  </div>
  <div class="sub-rows" id="sub-cogs">
    <div class="sub-row">
      <div class="sub-label" style="background:#FAECE7;border-color:#F5C4B3;color:#993C1D">원재료비</div>
      <div class="sub-bar-track"><div class="sub-bar-fill" id="sb-raw" style="background:#F0997B;width:0%"></div><span class="sub-bar-label" id="sl-raw" style="color:#712B13"></span></div>
    </div>
    <div class="sub-row">
      <div class="sub-label" style="background:#FAECE7;border-color:#F5C4B3;color:#993C1D">직접노동비</div>
      <div class="sub-bar-track"><div class="sub-bar-fill" id="sb-labor" style="background:#F0997B;width:0%"></div><span class="sub-bar-label" id="sl-labor" style="color:#712B13"></span></div>
    </div>
    <div class="sub-row">
      <div class="sub-label" style="background:#FAECE7;border-color:#F5C4B3;color:#993C1D">제조간접비</div>
      <div class="sub-bar-track"><div class="sub-bar-fill" id="sb-overhead" style="background:#F0997B;width:0%"></div><span class="sub-bar-label" id="sl-overhead" style="color:#712B13"></span></div>
    </div>
  </div>

  <!-- C. 매출총이익 -->
  <div class="row faded" id="row-gross">
    <div class="label-col">
      <div class="label-box" style="background:#E1F5EE;border-color:#0F6E56;color:#085041;">
        C. 매출총이익<span style="color:#0F6E56">A − B</span>
      </div>
    </div>
    <div class="op-badge" style="color:#1D9E75">=</div>
    <div class="bar-col">
      <div class="bar-track">
        <div class="bar-fill" id="bar-gross" style="background:#1D9E75;width:0%"></div>
        <span class="bar-label" id="lbl-gross" style="color:#085041"></span>
      </div>
    </div>
  </div>

  <!-- D. 판매관리비 -->
  <div class="row faded" id="row-sga">
    <div class="label-col">
      <div class="label-box" style="background:#FAEEDA;border-color:#854F0B;color:#633806;">
        D. 판매관리비 (SG&amp;A)<span style="color:#854F0B">판매비·관리비</span>
      </div>
    </div>
    <div class="op-badge" style="color:#BA7517">−</div>
    <div class="bar-col">
      <div class="bar-track">
        <div class="bar-fill" id="bar-sga" style="background:#EF9F27;width:0%"></div>
        <span class="bar-label" id="lbl-sga" style="color:#633806"></span>
      </div>
    </div>
  </div>
  <div class="sub-rows" id="sub-sga">
    <div class="sub-row">
      <div class="sub-label" style="background:#FAEEDA;border-color:#FAC775;color:#854F0B">판매비 (마케팅·광고·물류)</div>
      <div class="sub-bar-track"><div class="sub-bar-fill" id="sb-selling" style="background:#FAC775;width:0%"></div><span class="sub-bar-label" id="sl-selling" style="color:#633806"></span></div>
    </div>
    <div class="sub-row">
      <div class="sub-label" style="background:#FAEEDA;border-color:#FAC775;color:#854F0B">관리비 (임대·급여·법무)</div>
      <div class="sub-bar-track"><div class="sub-bar-fill" id="sb-admin" style="background:#FAC775;width:0%"></div><span class="sub-bar-label" id="sl-admin" style="color:#633806"></span></div>
    </div>
  </div>

  <!-- E. 영업이익 -->
  <div class="row faded" id="row-op">
    <div class="label-col">
      <div class="label-box" style="background:#EAF3DE;border-color:#3B6D11;color:#27500A;">
        E. 영업이익<span style="color:#3B6D11">C − D</span>
      </div>
    </div>
    <div class="op-badge" style="color:#639922">=</div>
    <div class="bar-col">
      <div class="bar-track">
        <div class="bar-fill" id="bar-op" style="background:#639922;width:0%"></div>
        <span class="bar-label" id="lbl-op" style="color:#27500A"></span>
      </div>
    </div>
  </div>

  <!-- 비영업비용 -->
  <div class="row faded" id="row-nonop">
    <div class="label-col">
      <div class="label-box" style="background:#F1EFE8;border-color:#5F5E5A;color:#444441;">
        비영업비용<span style="color:#5F5E5A">이자·법인세·기타손실</span>
      </div>
    </div>
    <div class="op-badge" style="color:#888780">−</div>
    <div class="bar-col">
      <div class="bar-track">
        <div class="bar-fill" id="bar-nonop" style="background:#888780;width:0%"></div>
        <span class="bar-label" id="lbl-nonop" style="color:#444441"></span>
      </div>
    </div>
  </div>

  <!-- F. 순이익 -->
  <div class="row faded" id="row-net">
    <div class="label-col">
      <div class="label-box" style="background:#EEEDFE;border-color:#534AB7;color:#3C3489;">
        F. 순이익<span style="color:#534AB7">주주 실질 이익</span>
      </div>
    </div>
    <div class="op-badge" style="color:#7F77DD">=</div>
    <div class="bar-col">
      <div class="bar-track">
        <div class="bar-fill" id="bar-net" style="background:#7F77DD;width:0%"></div>
        <span class="bar-label" id="lbl-net" style="color:#3C3489"></span>
      </div>
    </div>
  </div>

  <div class="controls">
    <button id="btn-prev" onclick="prev()">← 이전</button>
    <button id="btn-next" onclick="next()">시작 ▶</button>
    <button class="btn-reset" onclick="reset()">↺ 처음</button>
    <div class="step-dots" id="dots"></div>
  </div>
</div>

<script>
const STEPS = [
  {
    label: "1단계 — 매출액(A): 제품을 팔아 벌어들인 총 수입",
    show: ['row-revenue'],
    subs: ['sub-revenue'],
    bars: { 'bar-revenue':100,'sb-domestic':50,'sb-export':30,'sb-online':20 },
    labels: { 'lbl-revenue':'100%','sl-domestic':'50%','sl-export':'30%','sl-online':'20%' }
  },
  {
    label: "2단계 — 판매원가(B) 차감: 원재료비·노동비·제조간접비 제외",
    show: ['row-revenue','row-cogs'],
    subs: ['sub-revenue','sub-cogs'],
    bars: { 'bar-revenue':100,'sb-domestic':50,'sb-export':30,'sb-online':20,'bar-cogs':60,'sb-raw':30,'sb-labor':18,'sb-overhead':12 },
    labels: { 'lbl-revenue':'100%','sl-domestic':'50%','sl-export':'30%','sl-online':'20%','lbl-cogs':'60%','sl-raw':'30%','sl-labor':'18%','sl-overhead':'12%' }
  },
  {
    label: "3단계 — 매출총이익(C) = A − B : 생산 원가를 뺀 이익",
    show: ['row-revenue','row-cogs','row-gross'],
    subs: ['sub-revenue','sub-cogs'],
    bars: { 'bar-revenue':100,'sb-domestic':50,'sb-export':30,'sb-online':20,'bar-cogs':60,'sb-raw':30,'sb-labor':18,'sb-overhead':12,'bar-gross':40 },
    labels: { 'lbl-revenue':'100%','sl-domestic':'50%','sl-export':'30%','sl-online':'20%','lbl-cogs':'60%','sl-raw':'30%','sl-labor':'18%','sl-overhead':'12%','lbl-gross':'40%' }
  },
  {
    label: "4단계 — 판매관리비(D) 차감: 마케팅·물류·임대료·인건비 제외",
    show: ['row-revenue','row-cogs','row-gross','row-sga'],
    subs: ['sub-revenue','sub-cogs','sub-sga'],
    bars: { 'bar-revenue':100,'sb-domestic':50,'sb-export':30,'sb-online':20,'bar-cogs':60,'sb-raw':30,'sb-labor':18,'sb-overhead':12,'bar-gross':40,'bar-sga':20,'sb-selling':12,'sb-admin':8 },
    labels: { 'lbl-revenue':'100%','sl-domestic':'50%','sl-export':'30%','sl-online':'20%','lbl-cogs':'60%','sl-raw':'30%','sl-labor':'18%','sl-overhead':'12%','lbl-gross':'40%','lbl-sga':'20%','sl-selling':'12%','sl-admin':'8%' }
  },
  {
    label: "5단계 — 영업이익(E) = C − D : 본업에서 남긴 이익",
    show: ['row-revenue','row-cogs','row-gross','row-sga','row-op'],
    subs: ['sub-revenue','sub-cogs','sub-sga'],
    bars: { 'bar-revenue':100,'sb-domestic':50,'sb-export':30,'sb-online':20,'bar-cogs':60,'sb-raw':30,'sb-labor':18,'sb-overhead':12,'bar-gross':40,'bar-sga':20,'sb-selling':12,'sb-admin':8,'bar-op':20 },
    labels: { 'lbl-revenue':'100%','sl-domestic':'50%','sl-export':'30%','sl-online':'20%','lbl-cogs':'60%','sl-raw':'30%','sl-labor':'18%','sl-overhead':'12%','lbl-gross':'40%','lbl-sga':'20%','sl-selling':'12%','sl-admin':'8%','lbl-op':'20%' }
  },
  {
    label: "6단계 — 비영업비용 차감: 이자비용·법인세·기타손실 제외",
    show: ['row-revenue','row-cogs','row-gross','row-sga','row-op','row-nonop'],
    subs: ['sub-revenue','sub-cogs','sub-sga'],
    bars: { 'bar-revenue':100,'sb-domestic':50,'sb-export':30,'sb-online':20,'bar-cogs':60,'sb-raw':30,'sb-labor':18,'sb-overhead':12,'bar-gross':40,'bar-sga':20,'sb-selling':12,'sb-admin':8,'bar-op':20,'bar-nonop':8 },
    labels: { 'lbl-revenue':'100%','sl-domestic':'50%','sl-export':'30%','sl-online':'20%','lbl-cogs':'60%','sl-raw':'30%','sl-labor':'18%','sl-overhead':'12%','lbl-gross':'40%','lbl-sga':'20%','sl-selling':'12%','sl-admin':'8%','lbl-op':'20%','lbl-nonop':'8%' }
  },
  {
    label: "7단계 — 순이익(F) = 주주에게 돌아가는 최종 이익",
    show: ['row-revenue','row-cogs','row-gross','row-sga','row-op','row-nonop','row-net'],
    subs: ['sub-revenue','sub-cogs','sub-sga'],
    bars: { 'bar-revenue':100,'sb-domestic':50,'sb-export':30,'sb-online':20,'bar-cogs':60,'sb-raw':30,'sb-labor':18,'sb-overhead':12,'bar-gross':40,'bar-sga':20,'sb-selling':12,'sb-admin':8,'bar-op':20,'bar-nonop':8,'bar-net':12 },
    labels: { 'lbl-revenue':'100%','sl-domestic':'50%','sl-export':'30%','sl-online':'20%','lbl-cogs':'60%','sl-raw':'30%','sl-labor':'18%','sl-overhead':'12%','lbl-gross':'40%','lbl-sga':'20%','sl-selling':'12%','sl-admin':'8%','lbl-op':'20%','lbl-nonop':'8%','lbl-net':'12%' }
  }
];

const ALL_ROWS = ['row-revenue','row-cogs','row-gross','row-sga','row-op','row-nonop','row-net'];
const ALL_SUBS = ['sub-revenue','sub-cogs','sub-sga'];
const ALL_BARS = ['bar-revenue','bar-cogs','bar-gross','bar-sga','bar-op','bar-nonop','bar-net','sb-domestic','sb-export','sb-online','sb-raw','sb-labor','sb-overhead','sb-selling','sb-admin'];
const ALL_LBLS = ['lbl-revenue','lbl-cogs','lbl-gross','lbl-sga','lbl-op','lbl-nonop','lbl-net','sl-domestic','sl-export','sl-online','sl-raw','sl-labor','sl-overhead','sl-selling','sl-admin'];

let cur = -1;

function buildDots() {
  const c = document.getElementById('dots');
  c.innerHTML = '';
  STEPS.forEach((_,i) => {
    const d = document.createElement('div');
    d.className = 'dot' + (i === cur ? ' active' : '');
    c.appendChild(d);
  });
}

function applyStep(s) {
  ALL_ROWS.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.toggle('faded', !s.show.includes(id));
  });
  ALL_SUBS.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.toggle('open', s.subs && s.subs.includes(id));
  });
  ALL_BARS.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.style.width = ((s.bars && s.bars[id]) || 0) + '%';
  });
  ALL_LBLS.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = (s.labels && s.labels[id]) || '';
  });
  document.getElementById('step-label').textContent = s.label;
  document.getElementById('btn-prev').disabled = cur <= 0;
  document.getElementById('btn-next').textContent = cur >= STEPS.length - 1 ? '완료 ✓' : '다음 →';
  buildDots();
}

function next() {
  if (cur < STEPS.length - 1) { cur++; applyStep(STEPS[cur]); }
}
function prev() {
  if (cur > 0) { cur--; applyStep(STEPS[cur]); }
}
function reset() {
  cur = -1;
  ALL_ROWS.forEach(id => { const el = document.getElementById(id); if (el) el.classList.add('faded'); });
  ALL_SUBS.forEach(id => { const el = document.getElementById(id); if (el) el.classList.remove('open'); });
  ALL_BARS.forEach(id => { const el = document.getElementById(id); if (el) el.style.width = '0%'; });
  ALL_LBLS.forEach(id => { const el = document.getElementById(id); if (el) el.textContent = ''; });
  document.getElementById('step-label').textContent = '▶ 시작을 눌러 단계별로 확인하세요';
  document.getElementById('btn-next').textContent = '시작 ▶';
  document.getElementById('btn-prev').disabled = true;
  buildDots();
}

document.getElementById('btn-prev').disabled = true;
buildDots();

document.addEventListener('keydown', e => {
  if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next();
  if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') prev();
});
</script>
</body>
</html>
